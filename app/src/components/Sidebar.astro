            <span class:list={[
              "absolute left-0 top-1/2 -translate-y-1/2 h-8 w-0.5 rounded-full",
              { "bg-primary": isActive(currentPath, `${import.meta.env.BASE_URL}dashboard`) }
            ]}></span>
