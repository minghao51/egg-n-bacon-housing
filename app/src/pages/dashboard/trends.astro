---
import Layout from '@/layouts/Layout.astro';
import Sidebar from '@/components/Sidebar.astro';
import TrendsDashboard from '@/components/dashboard/TrendsDashboard';
import fs from 'fs';
import path from 'path';
import zlib from 'zlib';

// Read gzipped JSON at build time
function loadGzippedJson(relativePath) {
  try {
    const fullPath = path.resolve(relativePath);
    const decompressed = zlib.gunzipSync(fs.readFileSync(fullPath)).toString('utf-8');
    return JSON.parse(decompressed);
  } catch (error) {
    console.error(`Failed to load ${relativePath}:`, error);
    return null;
  }
}

const mrtCbdData = loadGzippedJson('public/data/interactive_tools/mrt_cbd_impact.json.gz');
const leaseDecayData = loadGzippedJson('public/data/interactive_tools/lease_decay_analysis.json.gz');
const affordabilityData = loadGzippedJson('public/data/interactive_tools/affordability_metrics.json.gz');
const hotspotsData = loadGzippedJson('public/data/interactive_tools/spatial_hotspots.json.gz');
const segmentsData = loadGzippedJson('public/data/segments_enhanced.json.gz');
---

<Layout title="Decision Tools - Dashboard">
  <Sidebar currentPath={Astro.url.pathname} />

  <main class="flex-1 pt-14 lg:pt-0 ml-0 lg:ml-64 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 py-8">
      {/* Header */}
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-foreground">Decision Tools</h1>
        <p class="text-muted-foreground mt-2">
          Use this page when you already have a concrete question and want a scenario calculator, not a broad exploration view.
        </p>
      </header>

      {/* Dashboard Content */}
      <TrendsDashboard
        client:load
        mrtCbdData={mrtCbdData}
        leaseDecayData={leaseDecayData}
        affordabilityData={affordabilityData}
        hotspotsData={hotspotsData}
        segmentsData={segmentsData}
      />
    </div>
  </main>
</Layout>
